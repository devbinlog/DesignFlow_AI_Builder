# DesignFlow AI Builder — 환경 변수 템플릿
# 이 파일을 루트의 .env로 복사한 후 실제 값을 입력하세요.
# cp infra/env/.env.example .env

# ─────────────────────────────────────
# 필수 변수 (반드시 설정)
# ─────────────────────────────────────

# Anthropic API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 데이터베이스 연결 문자열 (docker-compose 사용 시 아래 값 사용)
DATABASE_URL=postgresql+asyncpg://designflow:password@localhost:5432/designflow

# 프론트엔드 → 백엔드 API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─────────────────────────────────────
# 선택 변수 (기본값 있음)
# ─────────────────────────────────────

# AI 모델 (변경 시 프롬프트 품질 검증 필요)
AI_MODEL=claude-sonnet-4-6

# AI 응답 최대 토큰 수
AI_MAX_TOKENS=4096

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# CORS 허용 오리진 (JSON 배열 형식)
CORS_ORIGINS=["http://localhost:3000"]

# 최대 업로드 파일 크기 (MB)
MAX_FILE_SIZE_MB=10
